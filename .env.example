# LLM (Stage 1 + analyst)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Supabase (state + storage)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Asset providers — n8n reads only ELEVENLABS_VOICE_ID via $env; the API keys
# below are attached as n8n credentials in the UI (listed here for reference
# and local testing only; setting them does not wire anything up by itself).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
GOOGLE_AI_STUDIO_API_KEY=
# Publishing/analytics — YOUTUBE_API_KEY is read by agents/trend_scraper.py;
# IG_USER_ID via n8n $env; the rest are n8n-UI credentials (reference only).
YOUTUBE_API_KEY=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
IG_USER_ID=
INSTAGRAM_ACCESS_TOKEN=
# Render server
RENDER_SERVER_PORT=3333
RENDERS_BUCKET=renders
